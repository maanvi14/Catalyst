# Catalyst Frontend Environment Configuration Example
# Copy this file to .env and configure the variables.

# Base URL of the FastAPI backend service. 
# Next.js loads variables prefixed with NEXT_PUBLIC_ in the browser context.
# In local development: http://localhost:8000/api/v1
# In production deployment: https://your-backend-app-name.onrender.com/api/v1
NEXT_PUBLIC_API_BASE_URL=https://your-backend-service-url.onrender.com/api/v1
