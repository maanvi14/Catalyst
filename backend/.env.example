# Catalyst Backend Environment Configuration Example
# Copy this file to .env and configure the variables.

# Core FastAPI Configuration
APP_NAME="Catalyst API"
APP_ENV=production
API_PREFIX=/api/v1

# SQLite Database Location
DATABASE_URL=sqlite:///./catalyst.db

# CORS Allowed Origins (Comma-separated list, wildcards supported)
CORS_ORIGINS=https://*.vercel.app,http://localhost:5173

# Fixture Loading Properties
FIXTURE_DIR=../fixtures/nwl-26b
AUTO_LOAD_FIXTURES=true

# Groq Cloud API Key (Get yours from console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Hybrid Semantic RAG Configuration
ENABLE_SEMANTIC_RAG=true
